# 0G Storage Configuration
# Get a testnet private key from https://0g.ai

# Your private key for 0G testnet (without 0x prefix)
ZERO_G_PRIVATE_KEY=your_private_key_here

# Optional: fallback LLM for tool generation and test case generation
OPENAI_API_KEY=your_openai_key_here

# Optional: ENS identity publishing on Sepolia
ENS_PRIVATE_KEY=your_ens_owner_private_key_here
ENS_NAME=my-agent.eth
SEPOLIA_RPC_URL=https://sepolia.drpc.org
