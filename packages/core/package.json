{
  "name": "@zero-agents/core",
  "version": "0.0.1",
  "description": "ENS-native self-evolving agent framework with persistent 0G tool memory",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage/zero-g": {
      "types": "./dist/storage/zero-g.d.ts",
      "import": "./dist/storage/zero-g.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amirjaved-dev/zero-agents.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Amirjaved-dev/zero-agents#readme",
  "bugs": {
    "url": "https://github.com/Amirjaved-dev/zero-agents/issues"
  },
  "license": "MIT",
  "keywords": [
    "ai-agent",
    "agents",
    "zeroagent",
    "0g",
    "ens",
    "ethereum",
    "tool-generation",
    "self-evolving",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "pnpm build",
    "test:unit": "tsx src/__tests__/sandbox.test.ts && tsx src/__tests__/evaluator.test.ts && tsx src/__tests__/errors.test.ts && tsx src/__tests__/coordinator-safety.test.ts && tsx src/__tests__/tool-registry.test.ts && tsx src/__tests__/axl-client.test.ts && tsx src/__tests__/agent-strategy.test.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@0glabs/0g-serving-broker": "^0.7.5",
    "ethers": "^6.10.0",
    "isolated-vm": "^6.1.2",
    "openai": "^4.26.0",
    "viem": "^2.8.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "author": "ZeroAgent contributors"
}
